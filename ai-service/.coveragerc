# Cobertura unificada para Sonar (un solo <source> en coverage.xml).
# Varias banderas --cov= provocaban varias raíces y ambigüedad de __init__.py.
[run]
branch = false
relative_files = True
omit =
    tests/*
    */tests/*
    evaluate.py
    main.py
    models/campaign.py
    models/demand.py
    services/firebase_verifier.py

[report]
omit =
    tests/*
    */tests/*
    evaluate.py
    main.py
    models/campaign.py
    models/demand.py
    services/firebase_verifier.py
