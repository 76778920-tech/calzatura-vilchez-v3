# Copiar a load-tests/config.env (NO commitear secretos) y cargar antes de k6.
# PowerShell: Get-Content load-tests/config.env | ForEach-Object { ... } o usar run-load-test.ps1

# Entorno: local | staging | production
LOAD_ENV=staging

# Bloqueo de seguridad: solo true con ventana aprobada en producción
ALLOW_PROD_LOAD=false

# Supabase (obligatorio) — usar proyecto de STAGING para pruebas fuertes
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_ANON_KEY=tu_anon_key

# BFF Render (lectura: /public/catalog/*, /health, /delivery/quote)
BFF_BASE_URL=https://tu-bff.onrender.com

# Bypass rate-limit BFF en pruebas controladas (mismo valor que LOAD_TEST_TOKEN en Render o BFF local)
# LOAD_TEST_TOKEN=

# BFF local automático (npm run load:mixed1000:bff levanta http://127.0.0.1:8787)

# Hosting estático (Firebase)
HOSTING_URL=https://calzaturavilchez-ab17f.web.app

# IA (opcional, solo GET /api/health en mix)
# AI_SERVICE_URL=https://tu-ai.onrender.com

# Cotización envío de prueba (Lima centro por defecto)
DELIVERY_DEST_LAT=-12.0464
DELIVERY_DEST_LNG=-77.0428

# Perfil de carga (read-mixed-1000.js / read-mixed-2000.js)
# mixed1000 default: 350+200+150+100+80+80+40 = 1000 VUs
LOAD_CATALOG_VUS=1400
LOAD_BROWSE_VUS=350
LOAD_BFF_VUS=200
LOAD_HOSTING_VUS=50

# Duración de cada fase
LOAD_RAMP_UP=5m
LOAD_STEADY=10m
LOAD_RAMP_DOWN=2m
