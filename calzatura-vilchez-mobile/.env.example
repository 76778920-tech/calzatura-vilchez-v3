SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
# URL del servicio IA (admin predicciones Android). Cambiar ⇒ rebuild APK (Codemagic / flutter build).
AI_SERVICE_URL=https://calzatura-vilchez-v3.onrender.com
# Bearer hacia IA (Android admin). Web admin usa Firebase ID token vía aiAdminClient.
AI_SERVICE_BEARER_TOKEN=
SUPERADMIN_EMAIL=admin@example.com
# Misma URL que VITE_BACKEND_API_URL en la web (BFF Render)
BACKEND_API_URL=https://calzatura-vilchez-bff.onrender.com
# Misma URL que VITE_DNI_LOOKUP_URL (GitHub Secret / calzatura-vilchez/.env.local)
DNI_LOOKUP_URL=https://project-rif8c.vercel.app/api/lookup-dni
# Obligatorio para pago con tarjeta (pk_test_... o pk_live_...)
STRIPE_PUBLISHABLE_KEY=pk_test_...
