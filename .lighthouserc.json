{
  "ci": {
    "collect": {
      "staticDistDir": "./calzatura-vilchez/dist",
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--no-sandbox --headless --disable-gpu",
        "onlyCategories": ["performance", "accessibility", "best-practices", "seo"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":    ["warn",  { "minScore": 0.50 }],
        "categories:accessibility":  ["error", { "minScore": 0.80 }],
        "categories:best-practices": ["warn",  { "minScore": 0.80 }],
        "categories:seo":            ["warn",  { "minScore": 0.70 }],
        "largest-contentful-paint":  ["warn",  { "maxNumericValue": 6000 }],
        "cumulative-layout-shift":   ["warn",  { "maxNumericValue": 0.25 }],
        "total-blocking-time":       ["warn",  { "maxNumericValue": 1200 }],
        "first-contentful-paint":    ["warn",  { "maxNumericValue": 4000 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
