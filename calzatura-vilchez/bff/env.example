# Copiar a .env en Render (o exportar variables). Ver README.txt

# Firebase Admin (custom token en /authLogin)
# Opción A (Render / .env): JSON minificado en una línea (debe empezar por {)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Opción B (recomendada si no usas Secret File): JSON completo en Base64, una sola línea
# PowerShell (sin re-codificar UTF-8): [Convert]::ToBase64String([IO.File]::ReadAllBytes("$PWD\cuenta.json"))
# bash: base64 -w0 < cuenta.json
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# Opción C (muy fiable en Render): Secret File. Sube el .json en el dashboard y define la ruta:
#   FIREBASE_SERVICE_ACCOUNT_FILE=/etc/secrets/firebase-sa.json
# (el nombre del archivo coincide con el que configures en "Secret files")
FIREBASE_SERVICE_ACCOUNT_FILE=

# Misma clave web que usa el cliente (Identity Toolkit REST)
FIREBASE_WEB_API_KEY=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Correos autorizados para gestionar usuarios admin, separados por coma.
# El correo institucional principal está permitido por defecto en server.cjs.
SUPERADMIN_EMAILS=

# Libro de reclamaciones — aviso por correo (solo BFF; nunca VITE_*)
# Buzón dedicado recomendado (puede ser distinto del correo de login admin):
# COMPLAINT_NOTIFY_EMAIL=reclamaciones@tu-dominio.com
# Varias direcciones (máx. 5): COMPLAINT_NOTIFY_EMAIL=uno@mail.com,otro@mail.com
# Solo si no defines COMPLAINT_NOTIFY_EMAIL y quieres usar SUPERADMIN_EMAILS:
# COMPLAINT_NOTIFY_USE_SUPERADMIN=false
COMPLAINT_NOTIFY_EMAIL=
# Remitente verificado en https://resend.com (ej. Calzatura Vilchez <noreply@tu-dominio.com>)
RESEND_API_KEY=
COMPLAINT_EMAIL_FROM=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

AI_SERVICE_URL=
AI_SERVICE_BEARER_TOKEN=

# URL pública del frontend (Stripe success/cancel)
APP_URL=https://calzaturavilchez-ab17f.web.app

# Orígenes CORS extra separados por coma (opcional)
# ALLOWED_ORIGINS=https://tu-dominio.com

# Consulta DNI (POST /lookup-dni) — define al menos una:
# APISPERU_TOKEN — https://www.apisperu.com/servicios/dniruc (recomendado para personas naturales)
# CONSULTAS_PERU_TOKEN, APIPERU_DEV_TOKEN, API_INTI_TOKEN, PERUAPI_TOKEN o TOKEN_PERUAPI,
# LATINFO_API_KEY (solo entidades legales; personas → out_of_scope)
APISPERU_TOKEN=
# CONSULTAS_PERU_TOKEN=
# APIPERU_DEV_TOKEN=
# PERUAPI_TOKEN=

# Seguridad DNI en producción: el BFF falla cerrado si faltan.
REQUIRE_DNI_APPCHECK=true
DNI_LOOKUP_PROOF_SECRET=
# Para desarrollo local únicamente. En producción se ignoran los overrides de apagado:
# REQUIRE_DNI_APPCHECK=false
# REQUIRE_DNI_PROOF_SECRET=false

# Google Maps — distancia y ruta de envío (Directions API; recomendado en producción)
# Solo en el BFF (nunca VITE_* ni en el navegador). Habilitar "Directions API" en Google Cloud.
GOOGLE_MAPS_API_KEY=

# OpenRouteService (fallback /ors/* y geocoding legado si no hay Google)
ORS_API_KEY=

# Tarifa de envío (createOrder recalcula envío; deben coincidir con VITE_DELIVERY_* del front)
DELIVERY_BASE_PRICE=3
DELIVERY_PRICE_PER_KM=2
DELIVERY_FREE_KM=2
DELIVERY_MAX_KM=15
STORE_LAT=-12.071054
STORE_LNG=-75.205806

# Cloudinary — subida firmada (POST /admin/media/cloudinary-signature)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# CLOUDINARY_UPLOAD_FOLDER=calzatura

PORT=8787
