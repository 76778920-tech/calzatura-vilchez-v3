# Copiar a .env en Render (o exportar variables). Ver README.txt

# Firebase Admin (custom token en /authLogin)
# Opción A (Render / .env): JSON minificado en una línea (debe empezar por {)
FIREBASE_SERVICE_ACCOUNT_JSON=
# Opción B (recomendada si no usas Secret File): JSON completo en Base64, una sola línea
# PowerShell (sin re-codificar UTF-8): [Convert]::ToBase64String([IO.File]::ReadAllBytes("$PWD\cuenta.json"))
# bash: base64 -w0 < cuenta.json
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=
# Opción C (muy fiable en Render): Secret File. Sube el .json en el dashboard y define la ruta:
#   FIREBASE_SERVICE_ACCOUNT_FILE=/etc/secrets/firebase-sa.json
# (el nombre del archivo coincide con el que configures en "Secret files")
FIREBASE_SERVICE_ACCOUNT_FILE=

# Misma clave web que usa el cliente (Identity Toolkit REST)
FIREBASE_WEB_API_KEY=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

AI_SERVICE_URL=
AI_SERVICE_BEARER_TOKEN=

# URL pública del frontend (Stripe success/cancel)
APP_URL=https://calzaturavilchez-ab17f.web.app

# Orígenes CORS extra separados por coma (opcional)
# ALLOWED_ORIGINS=https://tu-dominio.com

# OpenRouteService (proxy /ors/* — evita 403 por referrer en el navegador)
# Misma clave que VITE_ORS_API_KEY en el front; en Render solo hace falta aquí si el front usa el BFF.
ORS_API_KEY=

PORT=8787
