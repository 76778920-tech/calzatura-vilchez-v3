# Copia a `functions/.env` (no subir a git) o define el parámetro en Google Cloud Console
# para la función `authLogin` (Firebase Functions v2 / params).
#
# Misma "Web API Key" que en el cliente (VITE_FIREBASE_API_KEY); no es un secreto de servidor,
# pero solo la usa el BFF para llamar a Identity Toolkit sin exponer la respuesta 400 al navegador.
FIREBASE_WEB_API_KEY=
