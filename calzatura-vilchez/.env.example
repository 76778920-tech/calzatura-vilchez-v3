# Copia este archivo a .env y completa los valores

# Stripe - clave publica (pk_test_... o pk_live_...)
VITE_STRIPE_PUBLIC_KEY=pk_test_TU_CLAVE_PUBLICA_AQUI

# Consulta DNI - API propia en Vercel, sin token visible en React.
VITE_DNI_LOOKUP_URL=https://project-rif8c.vercel.app/api/lookup-dni

# Servicio de IA local. En Docker queda disponible en el puerto 8000 del equipo.
VITE_AI_SERVICE_URL=http://localhost:8000

# Cloudinary - datos publicos para subida unsigned desde el navegador
VITE_CLOUDINARY_CLOUD_NAME=dnenqnvbg
VITE_CLOUDINARY_UPLOAD_PRESET=calzatura_uploads
