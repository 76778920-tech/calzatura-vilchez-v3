# Copia a .env.local (no se sube a git) y rellena valores reales.

# OpenRouteService — geocodificación + matriz de distancia (checkout / envío)
# https://openrouteservice.org/dev/#/signup
VITE_ORS_API_KEY=

# Coordenadas de la tienda / almacén (Huancayo por defecto en código)
# VITE_STORE_LAT=-12.0686
# VITE_STORE_LNG=-75.2099

# Tarifas opcionales (por defecto: base 3, S/2/km, 2 km gratis, máx 15 km)
# VITE_DELIVERY_BASE_PRICE=3
# VITE_DELIVERY_PRICE_PER_KM=2
# VITE_DELIVERY_FREE_KM=2
# VITE_DELIVERY_MAX_KM=15
