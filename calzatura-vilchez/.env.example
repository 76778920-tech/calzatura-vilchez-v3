# Copia a .env.local (no se sube a git) y rellena valores reales.

# Login vía Cloud Function (opcional): desactiva el BFF en producción con 0 o false.
# Si no se define, en `npm run build` se usa automáticamente:
#   https://us-central1-<VITE_FIREBASE_PROJECT_ID>.cloudfunctions.net/authLogin
# VITE_AUTH_PROXY_LOGIN_URL=

# OpenRouteService — geocodificación + matriz de distancia (checkout / envío)
# https://openrouteservice.org/dev/#/signup
VITE_ORS_API_KEY=

# Coordenadas de la tienda / almacén (Huancayo; por defecto en código: -12.071054, -75.205806)
# VITE_STORE_LAT=-12.071054
# VITE_STORE_LNG=-75.205806

# Tarifas opcionales (por defecto: base 3, S/2/km, 2 km gratis, máx 15 km)
# VITE_DELIVERY_BASE_PRICE=3
# VITE_DELIVERY_PRICE_PER_KM=2
# VITE_DELIVERY_FREE_KM=2
# VITE_DELIVERY_MAX_KM=15

# Caja geográfica para sugerencias de dirección (minLat,minLon,maxLat,maxLon). Por defecto: valle de Huancayo.
# off | none | 0 desactiva (búsqueda a nivel Perú; pueden aparecer homónimos en Lima).
# VITE_GEOCODE_BBOX=-12.38,-75.55,-11.78,-74.78
