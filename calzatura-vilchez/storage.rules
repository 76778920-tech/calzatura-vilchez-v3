rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "76778920@continental.edu.pe"
        || (firestore.exists(/databases/(default)/documents/usuarios/$(request.auth.uid))
            && firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.rol == "admin")
      );
    }

    function isProductImage() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
    }

    match /productos/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin() && isProductImage();
      allow delete: if isAdmin();
    }

    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
