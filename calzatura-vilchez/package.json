{
  "name": "calzatura-vilchez",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-clean-env.mjs vite",
    "build:shared": "node scripts/build-shared-cjs.mjs",
    "build": "node scripts/build-shared-cjs.mjs && node scripts/run-clean-env.mjs tsc -b --next vite build",
    "dist": "npm run build",
    "typecheck": "node scripts/run-clean-env.mjs tsc -b",
    "quality": "npm run test && npm run lint && npm run typecheck && npm run build",
    "lint": "node scripts/run-clean-env.mjs eslint .",
    "lint:report": "node scripts/run-clean-env.mjs eslint . -f json -o eslint-report.json",
    "preview": "node scripts/run-clean-env.mjs vite preview",
    "test": "node scripts/run-clean-env.mjs vitest run",
    "test:watch": "node scripts/run-clean-env.mjs vitest",
    "test:coverage": "node scripts/run-clean-env.mjs vitest run --coverage",
    "test:coverage:sonar": "node scripts/run-clean-env.mjs vitest run --coverage && node scripts/fix-lcov-for-sonar.mjs",
    "sonar:preflight": "node scripts/sonar-preflight.mjs",
    "test:e2e": "node scripts/run-playwright.mjs test",
    "test:e2e:idoneidad": "node scripts/run-playwright.mjs test e2e/idoneidad-journey.spec.ts e2e/register-validation.spec.ts",
    "test:e2e:precision": "node scripts/run-playwright.mjs test e2e/cart-stock-validation.spec.ts e2e/admin-commercial-guards.spec.ts e2e/admin-sales.spec.ts",
    "test:e2e:interoperabilidad": "node scripts/run-playwright.mjs test e2e/checkout-cod-order.spec.ts e2e/checkout-stripe.spec.ts e2e/admin-predictions.spec.ts e2e/register-validation.spec.ts e2e/profile-save.spec.ts",
    "test:e2e:seguridad": "node scripts/run-playwright.mjs test e2e/seguridad-access-guards.spec.ts e2e/register-validation.spec.ts",
    "test:e2e:cumplimiento": "node scripts/run-playwright.mjs test e2e/cumplimiento-funcional-legal.spec.ts e2e/cookie-consent.spec.ts",
    "test:e2e:admin": "node scripts/run-playwright.mjs test e2e/admin-*.spec.ts",
    "test:e2e:admin:codes": "node scripts/run-playwright.mjs test e2e/admin-code-guards.spec.ts",
    "test:e2e:ui": "node scripts/run-playwright.mjs test --ui",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:start": "supabase start",
    "db:stop": "supabase stop"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.104.1",
    "@tailwindcss/vite": "^4.2.2",
    "@vis.gl/react-google-maps": "^1.8.3",
    "exceljs": "^4.4.0",
    "firebase": "^12.12.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.16.0",
    "tailwindcss": "^4.2.2"
  },
  "overrides": {
    "@grpc/grpc-js": "^1.14.3",
    "@protobufjs/utf8": "^1.1.1",
    "protobufjs": "^7.6.1",
    "retry-request": "^8.0.2",
    "teeny-request": "^10.1.2",
    "tmp": "^0.2.6",
    "uuid": "^11.1.1",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/google.maps": "^3.64.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.2",
    "node-forge": "^1.4.0",
    "sharp": "^0.34.5",
    "supabase": "^2.98.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.1.5"
  }
}
